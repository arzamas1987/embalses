# Embalses — local development environment
# Copy to .env and fill in real values; never commit .env

DATABASE_URL=postgres://postgres:postgres@localhost:5432/embalses?sslmode=disable
API_ADDR=:8080
MCP_ADDR=:8081
WEB_PORT=5173

# Optional — leave empty to disable assistant
GEMINI_API_KEY=
GEMINI_MODEL=

# Optional — leave empty to disable AEMET enrichment
AEMET_API_KEY=

APP_ENV=development

# Note: MCP service runs on port 8082 externally (8081 internally)
# due to port 8081 being used by another service on this machine.
